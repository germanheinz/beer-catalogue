meta {
  name: Create beer (Admin)
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/api/v1/beers
  body: json
  auth: basic
}

headers {
  Content-Type: application/json
}

auth:basic {
  username: admin
  password: admin123
}

body:json {
  {
    "name": "Heineken Zero",
    "abv": 0.0,
    "type": "LAGER",
    "description": "Non-alcoholic lager",
    "manufacturerId": 1
  }
}

settings {
  encodeUrl: true
}
