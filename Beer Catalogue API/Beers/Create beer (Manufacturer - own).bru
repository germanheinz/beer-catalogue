meta {
  name: Create beer (Manufacturer - own)
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/api/v1/beers
  body: json
  auth: basic
}

headers {
  Content-Type: application/json
}

auth:basic {
  username: heineken_user
  password: heineken123
}

body:json {
  {
    "name": "Heineken Dark",
    "abv": 5.0,
    "type": "ALE",
    "description": "A darker version",
    "manufacturerId": 1
  }
}

settings {
  encodeUrl: true
}
